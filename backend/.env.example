# ===============================================================
# EventFinder Backend — Environment Variables
# ===============================================================
# Kopiere diese Datei nach .env und fülle alle Werte aus:
#   cp .env.example .env
#
# WICHTIG: Committe NIEMALS die .env-Datei — sie enthält Secrets.
# ===============================================================

# ---------------------------------------------------------------
# App
# ---------------------------------------------------------------
PORT=4000
NODE_ENV=development

# ---------------------------------------------------------------
# Datenbank (muss mit docker-compose übereinstimmen)
# ---------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_USER=mysql
DB_PASSWORD=mysql
DB_NAME=eventfinder

# ---------------------------------------------------------------
# Redis
# ---------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------
# JWT — PFLICHTFELDER
# ---------------------------------------------------------------
# Sicheren Zufallsstring generieren:
#   openssl rand -base64 64
#
# ACHTUNG: Die App startet NICHT wenn JWT_SECRET leer oder
# auf den unsicheren Default "supersecret123" gesetzt ist.
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING

# Token-Ablaufzeit (z.B. 1h, 7d, 3600s)
JWT_EXPIRES_IN=1h

# ---------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------
# Zeitfenster in Millisekunden (60000 = 1 Minute)
THROTTLE_TTL_MS=60000
# Max. Requests pro Zeitfenster (alle Endpunkte)
THROTTLE_LIMIT=100
# Max. Login-Versuche pro Zeitfenster (POST /*/login)
THROTTLE_LOGIN_LIMIT=5

# ---------------------------------------------------------------
# CORS
# ---------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------
# Flyer OCR & LLM (optional — Flyer-Upload deaktiviert wenn leer)
# Groq API Key: https://console.groq.com
# ---------------------------------------------------------------
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY

# ---------------------------------------------------------------
# Backend-URL (wird vom Frontend-Proxy genutzt)
# ---------------------------------------------------------------
BACKEND_URL=http://localhost:4000

# ---------------------------------------------------------------
# Frontend-URL (für Links in E-Mails)
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# SMTP (E-Mail-Versand)
# ---------------------------------------------------------------
# Lokale Entwicklung: Mailhog (http://localhost:8025) oder Mailtrap
#
# Mailhog (läuft via Docker):
#   SMTP_HOST=mailhog
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   SMTP_USER=
#   SMTP_PASSWORD=
#
# Mailtrap:
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USER=<mailtrap-user>
#   SMTP_PASSWORD=<mailtrap-password>
#
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@regivo.de
